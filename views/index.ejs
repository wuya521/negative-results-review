<%- include('partials/head', { pageTitle: '' }) %>
<%- include('partials/nav') %>

<section class="hero hero--editorial" id="hero">
  <div class="hero-content">
    <p class="hero-issue">ISSUE 001 · 创刊号 · 2026 春</p>
    <div class="hero-rule"></div>
    <h1 class="hero-title">负 结 果 通 讯</h1>
    <p class="hero-subtitle">Negative Results Review</p>
    <p class="hero-subtitle-alt">Archive of Failed Methods and Honest Research Narratives</p>
    <div class="hero-rule"></div>
    <blockquote class="hero-quote">“不是所有研究都能成功，但都值得被记录。”</blockquote>
    <div class="hero-cta-row">
      <a href="#latest" class="hero-cta">进入档案室</a>
      <% if (currentUser) { %>
      <a href="/me" class="hero-cta hero-cta--secondary">进入会员工作台</a>
      <% } else { %>
      <a href="/register" class="hero-cta hero-cta--secondary">注册轻会员</a>
      <% } %>
    </div>
  </div>
  <div class="hero-meta">
    <span>非正式学术交流与电子选刊平台</span>
    <span>Est. 2026</span>
  </div>
</section>

<section class="section home-brief" id="about-brief">
  <div class="container home-grid-intro">
    <div>
      <div class="section-header fade-in">
        <span class="section-number">§ 01</span>
        <h2 class="section-title">刊物说明</h2>
        <span class="section-en">ABOUT THIS PUBLICATION</span>
      </div>
      <div class="intro-content fade-in">
        <p>《负结果通讯》记录科研里常被省略的部分：失败实验、被拒稿件、方法翻车、选题夭折，以及研究者在过程中的真实困惑与反思。</p>
        <p>它不是正式期刊，也不试图冒充正式期刊。它更像一间整理得比较克制的档案室，把那些本来会消失的经验保留下来，给后来者少走一点弯路。</p>
        <p class="intro-note">平台声明：所刊内容不用于职称评审、成果认定或正式学术评价，仅用于研究经验分享、方法归档与学术文化展示。</p>
      </div>
    </div>
    <aside class="home-side-note fade-in">
      <div class="home-side-note__box">
        <span class="home-side-note__label">MEMBER NOTE</span>
        <h3>轻会员不是社区绑架</h3>
        <p>会员系统只做三件事：收藏、通知、投稿归属。它服务阅读和投稿秩序，不打断你作为匿名叙述者的自由。</p>
        <% if (!currentUser) { %>
        <a href="/register" class="home-side-note__link">创建账号</a>
        <% } else { %>
        <a href="/me" class="home-side-note__link">查看工作台</a>
        <% } %>
      </div>
    </aside>
  </div>
</section>

<section class="section section--alt" id="featured">
  <div class="container home-featured-layout">
    <div>
      <div class="section-header fade-in">
        <span class="section-number">§ 02</span>
        <h2 class="section-title">本期专题</h2>
        <span class="section-en">SPECIAL ISSUE</span>
      </div>
      <div class="featured-box fade-in">
        <p class="featured-label">Vol. 1 · No. 1 · 专题策划</p>
        <h3 class="featured-title">当 p 值卡在 0.05 的边缘</h3>
        <p class="featured-desc">统计显著性的边界焦虑，往往不是技术问题，而是叙述权问题。这里收录那些差一点就被称为“有意义”的研究故事。</p>
        <% if (featured.length > 0) { %>
        <div class="home-featured-links">
          <% featured.forEach(function(a) { %>
          <a href="/article/<%= a.id %>" class="home-featured-link">
            <span>◆</span><%= a.title %>
          </a>
          <% }) %>
        </div>
        <% } %>
        <p class="featured-meta">Archive Ref: NRR-SI-001 · 2026.03</p>
      </div>
    </div>

    <div>
      <div class="section-header fade-in">
        <span class="section-number">§ 03</span>
        <h2 class="section-title">栏目入口</h2>
        <span class="section-en">COLUMNS</span>
      </div>
      <div class="columns-grid columns-grid--compact">
        <% var colData = [
          {idx:'COL.01',name:'负结果档案',desc:'统计不显著，但依然有意义'},
          {idx:'COL.02',name:'废稿回收站',desc:'被拒、被弃、被遗忘的文字'},
          {idx:'COL.03',name:'方法翻车实录',desc:'理论上完美，实践中一地鸡毛'},
          {idx:'COL.04',name:'Reviewer 鬼话档案',desc:'审稿意见里的逻辑黑洞'},
          {idx:'COL.05',name:'选题尸检报告',desc:'复盘胎死腹中的研究构想'},
          {idx:'COL.06',name:'学术情绪标本室',desc:'科研过程中的真实情绪'}
        ]; colData.forEach(function(c) { %>
        <a href="/archive?section=<%= encodeURIComponent(c.name) %>" class="col-card fade-in" data-index="<%= c.idx %>">
          <h3 class="col-card__title"><%= c.name %></h3>
          <p class="col-card__desc"><%= c.desc %></p>
          <span class="col-card__arrow">浏览归档 →</span>
        </a>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="section" id="latest">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-number">§ 04</span>
      <h2 class="section-title">最新入选</h2>
      <span class="section-en">RECENT ARCHIVES</span>
    </div>
    <% if (articles.length > 0) { %>
    <div class="article-list fade-in">
      <% articles.forEach(function(a, i) { %>
      <a href="/article/<%= a.id %>" class="article-item article-item--rich">
        <span class="article-index"><%= String(i+1).padStart(2,'0') %></span>
        <div>
          <h3 class="article-title"><%= a.title %></h3>
          <p class="article-excerpt">这篇稿件已进入公开档案。适合想快速了解一个失败经验、审稿困境或方法教训的读者继续深入阅读。</p>
          <div class="article-tags-row"><%- include('partials/tags', {a: a}) %></div>
        </div>
        <div class="article-meta-side article-meta-side--rich">
          <span class="article-column"><%= a.section %></span>
          <span class="article-date"><%= a.published_at ? a.published_at.substring(0,10).replace(/-/g,'.') : '' %></span>
          <span class="article-views"><%= a.view_count || 0 %> 阅读</span>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <p style="color:var(--text-light);font-size:.88rem;padding:2rem 0">暂无已发布稿件。</p>
    <% } %>
    <div class="home-actions-row">
      <a href="/archive" class="home-outline-btn">查看完整归档</a>
      <a href="/submit" class="home-outline-btn home-outline-btn--dark">前往投稿</a>
    </div>
  </div>
</section>

<section class="section section--alt" id="principles">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-number">§ 05</span>
      <h2 class="section-title">编辑原则</h2>
      <span class="section-en">EDITORIAL PRINCIPLES</span>
    </div>
    <div class="principles-grid fade-in">
      <div class="principle-item"><span class="principle-num">01</span><p class="principle-text"><strong>真实优先</strong>，鼓励如实记录，不鼓励虚构和夸张。</p></div>
      <div class="principle-item"><span class="principle-num">02</span><p class="principle-text"><strong>匿名保护</strong>，默认尊重投稿者的隐匿边界。</p></div>
      <div class="principle-item"><span class="principle-num">03</span><p class="principle-text"><strong>善意批评</strong>，只讨论现象与结构，不做个人攻击。</p></div>
      <div class="principle-item"><span class="principle-num">04</span><p class="principle-text"><strong>学术伦理</strong>，避免泄露未发表数据与可识别信息。</p></div>
      <div class="principle-item"><span class="principle-num">05</span><p class="principle-text"><strong>非正式出版</strong>，所有内容仅代表个人经历与观点。</p></div>
      <div class="principle-item"><span class="principle-num">06</span><p class="principle-text"><strong>长期归档</strong>，入选内容会持续开放，形成可检索的失败经验库。</p></div>
    </div>
  </div>
</section>

<section class="section section--dark" id="submit-cta">
  <div class="container">
    <div class="cta-content fade-in">
      <h2>把那些本来会消失的经验留下来</h2>
      <p>可以是一段实验失败记录，一篇被反复退回的稿件，或者一句让你哭笑不得的审稿意见。只要它有价值，就值得被存档。</p>
      <a href="/submit" class="btn-primary">前往投稿</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
