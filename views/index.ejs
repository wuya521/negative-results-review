<%- include('partials/head', { pageTitle: '' }) %>
<%- include('partials/nav') %>
<%
  const issueLeadName = currentIssue ? (currentIssue.lead_display_name || currentIssue.lead_username || '') : '';
  const issueCoName = currentIssue ? (currentIssue.co_display_name || currentIssue.co_username || '') : '';
%>

<section class="hero hero--editorial hero--broadcast" id="hero">
  <div class="hero-content hero-content--broadcast">
    <p class="hero-issue"><%= currentIssue ? `${currentIssue.issue_label} · 创刊号 · ${currentIssue.year} ${currentIssue.season || ''}` : 'ISSUE 001 · 2026' %></p>
    <div class="hero-rule"></div>
    <div class="broadcast-stage fade-in" id="broadcastStage">
      <div class="broadcast-stage__frame">
        <div class="broadcast-stage__head">
          <span class="broadcast-stage__label">档案馆播报机</span>
          <span class="broadcast-stage__meta"><%= broadcasts.length %> 条广播在线</span>
        </div>
        <div class="broadcast-stage__screen">
          <% if (broadcasts.length) { %>
            <% broadcasts.forEach(function(item, index) { %>
            <article class="broadcast-slide <%= index === 0 ? 'is-active' : '' %>" data-broadcast-slide>
              <div class="broadcast-slide__eyebrow">
                <span><%= item.type %></span>
                <span>BROADCAST <%= String(index + 1).padStart(3, '0') %></span>
              </div>
              <h2 class="broadcast-slide__title"><%= item.title %></h2>
              <% if (item.subtitle) { %><p class="broadcast-slide__subtitle"><%= item.subtitle %></p><% } %>
              <div class="broadcast-slide__body"><%= item.content %></div>
              <% if (item.signature_name || item.signature_title) { %>
              <div class="broadcast-slide__signature"><strong><%= item.signature_name %></strong><span><%= item.signature_title %></span></div>
              <% } %>
              <div class="broadcast-slide__actions">
                <% if (item.cta_link) { %>
                <a href="/broadcasts/<%= item.id %>/go" class="hero-cta"><%= item.cta_text || '查看广播' %></a>
                <% } else { %>
                <a href="/broadcasts/<%= item.id %>" class="hero-cta">查看广播</a>
                <% } %>
                <a href="/broadcasts" class="hero-cta hero-cta--secondary">历史广播馆</a>
              </div>
            </article>
            <% }) %>
          <% } else { %>
            <article class="broadcast-slide is-active" data-broadcast-slide>
              <div class="broadcast-slide__eyebrow"><span>editorial</span><span>STANDBY</span></div>
              <h2 class="broadcast-slide__title">档案馆播报机待命中</h2>
              <p class="broadcast-slide__subtitle">当前没有有效广播，首屏将保持创刊号静默状态。</p>
              <div class="broadcast-slide__actions">
                <a href="/archive" class="hero-cta">进入档案室</a>
                <a href="/submit" class="hero-cta hero-cta--secondary">前往投稿</a>
              </div>
            </article>
          <% } %>
        </div>
        <% if (broadcasts.length > 1) { %>
        <div class="broadcast-stage__controls">
          <button type="button" class="broadcast-nav" id="broadcastPrev">上一条</button>
          <div class="broadcast-dots" id="broadcastDots">
            <% broadcasts.forEach(function(item, index) { %>
            <button type="button" class="broadcast-dot <%= index === 0 ? 'is-active' : '' %>" data-broadcast-dot="<%= index %>"></button>
            <% }) %>
          </div>
          <button type="button" class="broadcast-nav" id="broadcastNext">下一条</button>
        </div>
        <% } %>
      </div>
    </div>
    <div class="hero-cta-row">
      <a href="#latest" class="hero-cta">进入档案室</a>
      <a href="/submit" class="hero-cta hero-cta--secondary">投稿并整理为馆藏排版</a>
    </div>
  </div>
  <div class="hero-meta">
    <span><%= currentIssue ? currentIssue.theme_title : 'Archive of Failed Methods and Honest Research Narratives' %></span>
    <span>Est. 2026</span>
  </div>
</section>

<section class="section home-brief" id="about-brief">
  <div class="container home-grid-intro">
    <div>
      <div class="section-header fade-in">
        <span class="section-number">§ 01</span>
        <h2 class="section-title">刊物说明</h2>
        <span class="section-en">ABOUT THIS PUBLICATION</span>
      </div>
      <div class="intro-content fade-in">
        <p>《负结果通讯》记录科研里常被省略的部分：失败实验、被拒稿件、方法翻车、选题夭折，以及研究者在过程中真实而克制的情绪。</p>
        <p>它不是正式期刊，也不试图冒充正式期刊。它更像一间整理得很克制的档案室，把那些本来会消失的经验保留下来。</p>
        <% if (currentIssue) { %>
        <p class="intro-note">本期馆藏：<strong><%= currentIssue.theme_title %></strong>。<%= currentIssue.theme_note || '' %></p>
        <% } %>
      </div>
    </div>
    <aside class="home-side-note fade-in">
      <div class="home-side-note__box">
        <span class="home-side-note__label">CURRENT ISSUE</span>
        <h3><%= currentIssue ? currentIssue.issue_label : 'ISSUE 001' %></h3>
        <p><%= currentIssue ? (currentIssue.theme_title || '创刊号主题筹备中') : '创刊号主题筹备中' %></p>
        <% if (issueLeadName || issueCoName) { %>
        <div class="issue-curator-meta">
          <% if (issueLeadName) { %>
          <span>主策展：<% if (currentIssue.lead_public_slug) { %><a href="/curators/<%= currentIssue.lead_public_slug %>"><%= issueLeadName %></a><% } else { %><%= issueLeadName %><% } %></span>
          <% } %>
          <% if (issueCoName) { %>
          <span>联合策展：<% if (currentIssue.co_public_slug) { %><a href="/curators/<%= currentIssue.co_public_slug %>"><%= issueCoName %></a><% } else { %><%= issueCoName %><% } %></span>
          <% } %>
        </div>
        <% } %>
        <a href="/broadcasts" class="home-side-note__link">查看广播馆</a>
      </div>
    </aside>
  </div>
</section>

<% if (curatorBoard && curatorBoard.length) { %>
<section class="section" id="board">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-number">§ 02A</span>
      <h2 class="section-title">馆务团队</h2>
      <span class="section-en">CURATORIAL BOARD</span>
    </div>
    <div class="curator-board fade-in">
      <% curatorBoard.forEach(function(curator) { %>
        <% if (curator.public_slug) { %>
        <a href="/curators/<%= curator.public_slug %>" class="curator-card curator-card--link">
        <% } else { %>
        <article class="curator-card">
        <% } %>
          <div class="curator-card__head">
            <span class="curator-card__badge"><%= curator.badge_label %></span>
            <span class="curator-card__role"><%= curator.public_title %></span>
          </div>
          <h3 class="curator-card__name"><%= curator.display_name %></h3>
          <% if (curator.bio) { %><p class="curator-card__bio"><%= curator.bio %></p><% } %>
          <div class="curator-card__meta"><span>@<%= curator.username %></span><span><%= curator.public_slug ? '查看人物页' : '馆务成员' %></span></div>
        <% if (curator.public_slug) { %>
        </a>
        <% } else { %>
        </article>
        <% } %>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section section--alt" id="featured">
  <div class="container home-featured-layout">
    <div>
      <div class="section-header fade-in">
        <span class="section-number">§ 02</span>
        <h2 class="section-title">本期专题</h2>
        <span class="section-en">SPECIAL ISSUE</span>
      </div>
      <div class="featured-box fade-in">
        <p class="featured-label"><%= currentIssue ? `${currentIssue.issue_label} · ${currentIssue.season || ''} ${currentIssue.year}` : 'Vol. 1 · No. 1' %></p>
        <h3 class="featured-title"><%= currentIssue ? currentIssue.theme_title : '当 p 值停在 0.05 的门外' %></h3>
        <p class="featured-desc"><%= currentIssue ? currentIssue.theme_note : '统计显著性的边界焦虑，往往不是技术问题，而是叙述权问题。' %></p>
        <% if (currentIssue && currentIssue.curator_statement) { %>
        <p class="featured-box__statement">“<%= currentIssue.curator_statement %>”</p>
        <% } %>
        <% if (issueLeadName || issueCoName) { %>
        <div class="featured-box__curators">
          <% if (issueLeadName) { %>
          <span>主策展：<% if (currentIssue.lead_public_slug) { %><a href="/curators/<%= currentIssue.lead_public_slug %>"><%= issueLeadName %></a><% } else { %><%= issueLeadName %><% } %></span>
          <% } %>
          <% if (issueCoName) { %>
          <span>联合策展：<% if (currentIssue.co_public_slug) { %><a href="/curators/<%= currentIssue.co_public_slug %>"><%= issueCoName %></a><% } else { %><%= issueCoName %><% } %></span>
          <% } %>
        </div>
        <% } %>
        <% if (featured.length > 0) { %>
        <div class="home-featured-links">
          <% featured.forEach(function(a) { %>
          <a href="/article/<%= a.id %>" class="home-featured-link"><span>◆</span><%= a.display_title || a.title %></a>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>

    <div>
      <div class="section-header fade-in">
        <span class="section-number">§ 03</span>
        <h2 class="section-title">栏目入口</h2>
        <span class="section-en">COLUMNS</span>
      </div>
      <div class="columns-grid columns-grid--compact">
        <% var colData = [
          {idx:'COL.01',name:'负结果档案',desc:'统计不显著，但依然有意义'},
          {idx:'COL.02',name:'废稿回收站',desc:'被拒、被弃、被遗忘的文字'},
          {idx:'COL.03',name:'方法翻车实录',desc:'理论上完美，实践中一地鸡毛'},
          {idx:'COL.04',name:'Reviewer 鬼话档案',desc:'审稿意见里的逻辑黑洞'},
          {idx:'COL.05',name:'选题尸检报告',desc:'复盘胎死腹中的研究构想'},
          {idx:'COL.06',name:'学术情绪标本室',desc:'科研过程中真实的心绪标本'}
        ]; colData.forEach(function(c) { %>
        <a href="/archive?section=<%= encodeURIComponent(c.name) %>" class="col-card fade-in" data-index="<%= c.idx %>">
          <h3 class="col-card__title"><%= c.name %></h3>
          <p class="col-card__desc"><%= c.desc %></p>
          <span class="col-card__arrow">浏览归档 →</span>
        </a>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="section" id="latest">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-number">§ 04</span>
      <h2 class="section-title">最新入馆</h2>
      <span class="section-en">RECENT ARCHIVES</span>
    </div>
    <% if (articles.length > 0) { %>
    <div class="article-list fade-in">
      <% articles.forEach(function(a, i) { %>
      <a href="/article/<%= a.id %>" class="article-item article-item--rich">
        <span class="article-index"><%= String(i+1).padStart(2,'0') %></span>
        <div>
          <h3 class="article-title"><%= a.display_title || a.title %></h3>
          <p class="article-excerpt"><%= a.excerpt || a.deck || '这篇稿件已进入公开档案，适合继续深入阅读。' %></p>
          <div class="article-tags-row"><%- include('partials/tags', {a: a}) %></div>
        </div>
        <div class="article-meta-side article-meta-side--rich">
          <span class="article-column"><%= a.section %></span>
          <span class="article-date"><%= a.published_at ? a.published_at.substring(0,10).replace(/-/g,'.') : '' %></span>
          <span class="article-views"><%= a.view_count || 0 %> 阅读</span>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <p style="color:var(--text-light);font-size:.88rem;padding:2rem 0">暂无已发布稿件。</p>
    <% } %>
    <div class="home-actions-row">
      <a href="/archive" class="home-outline-btn">查看完整归档</a>
      <a href="/submit" class="home-outline-btn home-outline-btn--dark">前往投稿</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script>
(function(){
  var slides = Array.prototype.slice.call(document.querySelectorAll('[data-broadcast-slide]'));
  var dots = Array.prototype.slice.call(document.querySelectorAll('[data-broadcast-dot]'));
  if (!slides.length) return;
  var current = 0;
  function render(index) {
    current = index;
    slides.forEach(function(slide, i) { slide.classList.toggle('is-active', i === index); });
    dots.forEach(function(dot, i) { dot.classList.toggle('is-active', i === index); });
  }
  var prev = document.getElementById('broadcastPrev');
  var next = document.getElementById('broadcastNext');
  if (prev) prev.addEventListener('click', function(){ render((current - 1 + slides.length) % slides.length); });
  if (next) next.addEventListener('click', function(){ render((current + 1) % slides.length); });
  dots.forEach(function(dot, index){ dot.addEventListener('click', function(){ render(index); }); });
  if (slides.length > 1) {
    setInterval(function(){ render((current + 1) % slides.length); }, 7000);
  }
})();
</script>
