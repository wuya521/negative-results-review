<%- include('partials/head', { pageTitle: '归档' }) %>
<%- include('partials/nav') %>

<header class="page-header">
  <div class="container">
    <p class="page-header__label">Archive / 归档</p>
    <h1 class="page-header__title">档案馆</h1>
    <p class="page-header__sub">所有已发布的稿件在此长期公开存档。</p>
  </div>
</header>

<main class="section">
  <div class="container">
    <form method="GET" action="/archive" style="display:flex;gap:.6rem;flex-wrap:wrap;align-items:center;margin-bottom:2rem;padding-bottom:1rem;border-bottom:1px solid var(--border)">
      <span style="font-size:.72rem;color:var(--text-light);letter-spacing:.06em">筛选</span>
      <select name="section" style="padding:.35rem .6rem;border:1px solid var(--border);border-radius:2px;font-size:.78rem;background:var(--bg)">
        <option value="">全部栏目</option>
        <% sections.forEach(function(s) { %><option value="<%= s %>" <%= filters.section===s?'selected':'' %>><%= s %></option><% }) %>
      </select>
      <select name="year" style="padding:.35rem .6rem;border:1px solid var(--border);border-radius:2px;font-size:.78rem;background:var(--bg)">
        <option value="">全部年份</option>
        <% years.forEach(function(y) { %><option value="<%= y %>" <%= filters.year===y?'selected':'' %>><%= y %></option><% }) %>
      </select>
      <label style="font-size:.78rem;color:var(--text-sec);display:flex;align-items:center;gap:.3rem;cursor:pointer">
        <input type="checkbox" name="featured" value="1" <%= filters.featured==='1'?'checked':'' %> style="accent-color:var(--accent)"> 仅精选
      </label>
      <input type="text" name="q" placeholder="搜索标题或学科…" value="<%= filters.q || '' %>" style="padding:.35rem .7rem;border:1px solid var(--border);border-radius:2px;font-size:.78rem;background:var(--bg);width:180px">
      <button type="submit" style="padding:.35rem .8rem;border:1px solid var(--border);border-radius:2px;font-size:.75rem;cursor:pointer;background:var(--bg)">搜索</button>
      <% if (filters.section||filters.year||filters.featured||filters.q) { %><a href="/archive" style="font-size:.72rem;color:var(--text-light)">清除</a><% } %>
    </form>

    <% if (articles.length > 0) { %>
    <div style="font-size:.7rem;color:var(--text-light);margin-bottom:1rem;font-family:var(--font-mono);letter-spacing:.06em">第 <%= page %>/<%= totalPages %> 页</div>
    <div class="article-list">
      <% articles.forEach(function(a, i) { %>
      <a href="/article/<%= a.id %>" class="article-item">
        <span class="article-index"><%= String((page-1)*10 + i+1).padStart(2,'0') %></span>
        <div>
          <h3 class="article-title"><%= a.title %></h3>
          <div class="article-tags-row"><%- include('partials/tags', {a: a}) %></div>
        </div>
        <div class="article-meta-side">
          <span class="article-column"><%= a.section %></span>
          <span class="article-date"><%= a.published_at ? a.published_at.substring(0,10).replace(/-/g,'.') : '' %></span>
        </div>
      </a>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% var qs = []; if(filters.section) qs.push('section='+encodeURIComponent(filters.section)); if(filters.year) qs.push('year='+filters.year); if(filters.featured) qs.push('featured=1'); if(filters.q) qs.push('q='+encodeURIComponent(filters.q)); var base='/archive?'+qs.join('&')+(qs.length?'&':''); %>
      <% if (page > 1) { %><a href="<%= base %>page=<%= page-1 %>" class="page-link">← 上一页</a><% } %>
      <span class="page-info"><%= page %> / <%= totalPages %></span>
      <% if (page < totalPages) { %><a href="<%= base %>page=<%= page+1 %>" class="page-link">下一页 →</a><% } %>
    </div>
    <% } %>
    <% } else { %>
    <div style="text-align:center;padding:4rem 1rem;color:var(--text-light)">
      <p style="font-size:1.5rem;opacity:.3;margin-bottom:.5rem">◇</p>
      <p>暂无匹配的归档文章。</p>
    </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
