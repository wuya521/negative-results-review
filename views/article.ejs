<%- include('partials/head', { pageTitle: article.title, pageDesc: (article.content||'').substring(0,150), ogType: 'article' }) %>
<%- include('partials/nav') %>

<header class="page-header">
  <div class="container">
    <p class="page-header__label">Archive No. <%= article.submission_no %></p>
    <h1 class="page-header__title">文章详情</h1>
  </div>
</header>

<main class="section">
  <div class="article-detail">
    <a href="javascript:history.back()" class="article-detail__back">← 返回</a>

    <header class="article-detail__header fade-in">
      <span class="article-detail__column"><%= article.section %></span>
      <h1 class="article-detail__title"><%= article.title %></h1>
      <div class="article-tags-row" style="margin-bottom:1rem">
        <%- include('partials/tags', { a: article }) %>
      </div>
      <div class="article-detail__meta">
        <span>作者：<%= article.author_mode === 'anonymous' ? '匿名' : (article.pen_name || '匿名') %></span>
        <span>日期：<%= article.published_at ? article.published_at.substring(0,10) : article.created_at.substring(0,10) %></span>
        <span>编号：<%= article.submission_no %></span>
        <span>学科：<%= article.discipline %></span>
        <span>约 <%= readingTime %> 分钟阅读</span>
        <span><%= article.view_count || 0 %> 次阅读</span>
      </div>
    </header>

    <!-- Share bar -->
    <div class="share-bar fade-in">
      <span class="share-label">分享：</span>
      <button class="share-btn" onclick="shareToWeibo()" title="分享到微博">微博</button>
      <button class="share-btn" onclick="copyLink()" title="复制链接" id="copyBtn">复制链接</button>
      <button class="share-btn" onclick="window.print()" title="打印">打印</button>
    </div>

    <% if (article.editor_note) { %>
    <div class="editor-note fade-in">
      <p class="editor-note__label">编辑部短评</p>
      <p><%= article.editor_note %></p>
    </div>
    <% } %>

    <article class="article-body fade-in">
      <%- formatContent(article.content) %>
    </article>

    <% if (article.value_note) { %>
    <div class="value-note-box fade-in">
      <span class="value-note-label">投稿者价值说明</span><br>
      <%= article.value_note %>
    </div>
    <% } %>

    <div class="article-tags fade-in">
      <span class="article-tag"><%= article.section %></span>
      <span class="article-tag"><%= article.discipline %></span>
      <% if (article.tags) { parseTags(article.tags).forEach(function(t) { %>
      <span class="article-tag"><%= t %></span>
      <% }) } %>
    </div>

    <!-- Related articles -->
    <% if (related && related.length > 0) { %>
    <div class="related-section fade-in">
      <h3 class="related-title">相关阅读</h3>
      <div class="related-grid">
        <% related.forEach(function(r) { %>
        <a href="/article/<%= r.id %>" class="related-card">
          <span class="related-card__section"><%= r.section %></span>
          <h4 class="related-card__title"><%= r.title %></h4>
          <span class="related-card__meta"><%= r.published_at ? r.published_at.substring(0,10) : '' %> · <%= r.view_count || 0 %> 次阅读</span>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Comments -->
    <div class="comments-section fade-in" id="comments">
      <h3 class="comments-title">读者留言 (<%= comments.length %>)</h3>

      <% if (comments.length > 0) { %>
      <div class="comments-list">
        <% comments.forEach(function(c) { %>
        <div class="comment-item">
          <div class="comment-header">
            <span class="comment-nick"><%= c.nickname %></span>
            <span class="comment-time"><%= c.created_at %></span>
          </div>
          <div class="comment-body"><%= c.content %></div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p class="comments-empty">还没有留言，来写第一条吧。</p>
      <% } %>

      <form class="comment-form" method="POST" action="/article/<%= article.id %>/comment">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="comment-form__row">
          <input type="text" name="nickname" placeholder="昵称（可选，默认匿名读者）" class="comment-input" maxlength="100">
        </div>
        <div class="comment-form__row">
          <textarea name="content" placeholder="写下你的想法…" class="comment-textarea" required maxlength="2000" rows="3"></textarea>
        </div>
        <button type="submit" class="btn-submit" style="padding:.6rem 2rem;font-size:.82rem">发表留言</button>
      </form>
    </div>

    <div style="margin-top:2.5rem">
      <a href="/archive" class="article-detail__back">← 浏览更多归档文章</a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script>
function shareToWeibo(){
  var u=encodeURIComponent(location.href),t=encodeURIComponent(document.title);
  window.open('https://service.weibo.com/share/share.php?url='+u+'&title='+t,'_blank','width=600,height=400');
}
function copyLink(){
  navigator.clipboard.writeText(location.href).then(function(){
    var b=document.getElementById('copyBtn');b.textContent='已复制';setTimeout(function(){b.textContent='复制链接'},2000);
  });
}
</script>
