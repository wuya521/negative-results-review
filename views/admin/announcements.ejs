<%- include('partials/head', { pageTitle: '播报机公告' }) %>
<body>
<div class="layout">
<%- include('partials/sidebar', { active: 'announcements', stats: stats, admin: admin }) %>
<div class="main">
  <header class="topbar">
    <div class="topbar-left">
      <button class="topbar-menu" id="menuBtn" aria-label="菜单">☰</button>
      <span class="topbar-issue">BROADCAST</span>
      <span class="topbar-status"><span class="dot"></span>档案馆播报机管理</span>
    </div>
  </header>

  <div class="content">
    <div class="sec-header">
      <h2>播报机公告</h2>
      <span class="tag">Announcements</span>
      <a href="/admin/announcements/new" class="export-btn">新建公告</a>
    </div>

    <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="detail-card" style="margin-bottom:1rem;font-size:.82rem;color:var(--text-sec)">
      <%= ({ created: '公告已创建。', saved: '公告已保存。', deleted: '公告已停用。', invalid: '请至少填写标题和正文。' })[msg] || msg %>
    </div>
    <% } %>

    <div class="member-admin-stack">
      <% if (!announcements.length) { %>
      <div class="empty-state"><div class="icon">✦</div>还没有播报机公告。</div>
      <% } %>
      <% announcements.forEach(function(item) { %>
      <article class="detail-card member-admin-record member-admin-record--link">
        <div>
          <div class="member-item__eyebrow"><%= item.type %> · audience/<%= item.audience %></div>
          <h4><a href="/admin/announcements/<%= item.id %>"><%= item.title %></a></h4>
          <p><%= item.subtitle || item.content %></p>
          <p>点击 <%= item.click_count || 0 %> · 展示 <%= item.impression_count || 0 %> · 优先级 <%= item.priority || 0 %></p>
        </div>
        <div class="member-item__meta-block">
          <span class="member-badge member-badge--<%= item.is_active ? 'approved' : 'rejected' %>"><%= item.is_active ? '在线' : '已停用' %></span>
          <% if (item.is_pinned) { %><span class="member-badge member-badge--pending">置顶</span><% } %>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</div>
</div>
<script>
var menuBtn=document.getElementById('menuBtn'),sidebar=document.getElementById('sidebar'),mobOv=document.getElementById('mobileOverlay');
if(menuBtn){menuBtn.onclick=function(){sidebar.classList.add('open');if(mobOv)mobOv.classList.add('open')}}
if(mobOv){mobOv.onclick=function(){sidebar.classList.remove('open');mobOv.classList.remove('open')}}
</script>
</body></html>

