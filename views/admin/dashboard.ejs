<%- include('partials/head', { pageTitle: '仪表盘' }) %>
<body>
<div class="layout">
<%- include('partials/sidebar', { active: 'dashboard', stats: stats, admin: admin }) %>
<div class="main">

  <header class="topbar">
    <div class="topbar-left">
      <button class="topbar-menu" id="menuBtn" aria-label="菜单">☰</button>
      <span class="topbar-issue">ISSUE 001</span>
      <span class="topbar-status"><span class="dot"></span>编辑部运行中</span>
    </div>
    <div class="topbar-right">
      <div class="topbar-stat"><div class="num"><%= todayCount %></div><div class="label">今日新稿</div></div>
      <div class="topbar-divider"></div>
      <div class="topbar-stat"><div class="num"><%= stats.pending %></div><div class="label">待审</div></div>
      <div class="topbar-divider"></div>
      <div class="topbar-stat"><div class="num"><%= stats.published %></div><div class="label">已发布</div></div>
      <div class="topbar-divider"></div>
      <div class="topbar-stat"><div class="num"><%= stats.total %></div><div class="label">总计</div></div>
    </div>
  </header>

  <div class="content">
    <div class="summary-row">
      <div class="summary-card accent"><div class="val"><%= stats.pending %></div><div class="lbl">待审稿件</div></div>
      <div class="summary-card"><div class="val"><%= stats.under_review + stats.revision %></div><div class="lbl">审核/退修中</div></div>
      <div class="summary-card"><div class="val"><%= stats.accepted %></div><div class="lbl">已录用待发布</div></div>
      <div class="summary-card"><div class="val"><%= stats.published %></div><div class="lbl">已发布</div></div>
    </div>

    <!-- Charts row -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem">
      <!-- Submission trend chart -->
      <div class="detail-card" style="margin-bottom:0">
        <h3 style="font-family:var(--font-serif);font-size:.92rem;font-weight:700;margin-bottom:1rem">近 30 天投稿趋势</h3>
        <div class="chart-bars" style="display:flex;align-items:flex-end;gap:2px;height:120px;padding-top:.5rem">
          <% var maxC = Math.max(1, ...weekData.map(function(d){return d.c}));
             weekData.forEach(function(d) { var pct = Math.round((d.c / maxC) * 100); %>
          <div class="chart-bar" style="flex:1;background:var(--accent);min-height:2px;height:<%= pct %>%;border-radius:1px 1px 0 0;position:relative" title="<%= d.day %>: <%= d.c %> 篇">
          </div>
          <% }) %>
          <% if (weekData.length === 0) { %>
          <div style="width:100%;text-align:center;color:var(--text-light);font-size:.78rem;align-self:center">暂无数据</div>
          <% } %>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:.3rem">
          <% if (weekData.length > 0) { %>
          <span style="font-size:.58rem;color:var(--text-light);font-family:var(--font-mono)"><%= weekData[0].day.substring(5) %></span>
          <span style="font-size:.58rem;color:var(--text-light);font-family:var(--font-mono)"><%= weekData[weekData.length-1].day.substring(5) %></span>
          <% } %>
        </div>
      </div>

      <!-- Section distribution -->
      <div class="detail-card" style="margin-bottom:0">
        <h3 style="font-family:var(--font-serif);font-size:.92rem;font-weight:700;margin-bottom:1rem">栏目分布</h3>
        <div style="display:flex;flex-direction:column;gap:.5rem">
          <% var maxSec = Math.max(1, ...sectionData.map(function(s){return s.c}));
             sectionData.forEach(function(s) { var pct = Math.round((s.c / maxSec) * 100); %>
          <div>
            <div style="display:flex;justify-content:space-between;font-size:.72rem;margin-bottom:.2rem">
              <span style="color:var(--text-sec)"><%= s.section %></span>
              <span style="font-family:var(--font-mono);color:var(--text-light)"><%= s.c %></span>
            </div>
            <div style="height:6px;background:var(--bg-alt);border-radius:3px;overflow:hidden">
              <div style="height:100%;width:<%= pct %>%;background:var(--accent);border-radius:3px;transition:width .5s"></div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="sec-header">
      <h2>最新投稿</h2>
      <span class="tag">Recent Submissions</span>
    </div>

    <div class="ms-list">
      <div class="ms-head">
        <span>#</span><span>标题</span><span>栏目</span><span>状态</span><span>日期</span><span>风险</span>
      </div>
      <% if (recent.length === 0) { %>
      <div class="empty-state"><div class="icon">◇</div>暂无稿件</div>
      <% } else { %>
      <% recent.forEach(function(m, i) { %>
      <a href="/admin/manuscripts/<%= m.id %>" class="ms-item" style="text-decoration:none;color:inherit">
        <span class="ms-idx"><%= String(i+1).padStart(2,'0') %></span>
        <span class="ms-title"><%= m.title %></span>
        <span class="ms-col"><%= m.section %></span>
        <span class="badge badge-<%= m.status %>"><%= statusLabel(m.status) %></span>
        <span class="ms-date"><%= m.created_at.substring(0,10) %></span>
        <span class="ms-risk <%= m.risk_level %>"></span>
      </a>
      <% }) %>
      <% } %>
    </div>

    <div style="margin-top:1.5rem;text-align:center">
      <a href="/admin/manuscripts" style="font-size:.8rem;color:var(--accent);letter-spacing:.06em">查看全部稿件 →</a>
    </div>
  </div>
</div>
</div>

<script>
var menuBtn=document.getElementById('menuBtn'),sidebar=document.getElementById('sidebar'),mobOv=document.getElementById('mobileOverlay');
if(menuBtn){menuBtn.onclick=function(){sidebar.classList.add('open');if(mobOv)mobOv.classList.add('open')}}
if(mobOv){mobOv.onclick=function(){sidebar.classList.remove('open');mobOv.classList.remove('open')}}
</script>
</body>
</html>
