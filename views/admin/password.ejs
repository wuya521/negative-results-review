<%- include('partials/head', { pageTitle: '修改密码' }) %>
<body>
<div class="layout">
<%- include('partials/sidebar', { active: 'password', stats: stats, admin: admin }) %>
<div class="main">
  <header class="topbar">
    <div class="topbar-left">
      <button class="topbar-menu" id="menuBtn" aria-label="菜单">☰</button>
      <span class="topbar-issue">ISSUE 001</span>
    </div>
    <div class="topbar-right"></div>
  </header>
  <div class="content">
    <div class="sec-header"><h2>修改密码</h2><span class="tag">Change Password</span></div>

    <% if (msg) { %>
    <% var msgMap = {success:'密码修改成功',empty:'请填写所有字段',too_short:'新密码至少 6 位',mismatch:'两次输入不一致',wrong_old:'旧密码错误'}; %>
    <div style="padding:.8rem 1.2rem;margin-bottom:1.5rem;font-size:.82rem;border-left:3px solid;<%= msg==='success'?'background:#EEF6EF;border-color:#3A7D44;color:#3A7D44':'background:#FDF0ED;border-color:#8B2500;color:#8B2500' %>">
      <%= msgMap[msg] || msg %>
    </div>
    <% } %>

    <form method="POST" action="/admin/password" class="edit-card" style="max-width:420px">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="edit-field" style="margin-bottom:1rem">
        <label>当前密码</label>
        <input type="password" name="old_password" required style="width:100%;padding:.5rem .8rem;border:1px solid var(--border);border-radius:2px;font-size:.85rem;background:#fff">
      </div>
      <div class="edit-field" style="margin-bottom:1rem">
        <label>新密码（至少 6 位）</label>
        <input type="password" name="new_password" required minlength="6" style="width:100%;padding:.5rem .8rem;border:1px solid var(--border);border-radius:2px;font-size:.85rem;background:#fff">
      </div>
      <div class="edit-field" style="margin-bottom:1rem">
        <label>确认新密码</label>
        <input type="password" name="confirm_password" required style="width:100%;padding:.5rem .8rem;border:1px solid var(--border);border-radius:2px;font-size:.85rem;background:#fff">
      </div>
      <button type="submit" class="btn-save">修改密码</button>
    </form>
  </div>
</div>
</div>
<script>
var menuBtn=document.getElementById('menuBtn'),sidebar=document.getElementById('sidebar'),mobOv=document.getElementById('mobileOverlay');
if(menuBtn){menuBtn.onclick=function(){sidebar.classList.add('open');if(mobOv)mobOv.classList.add('open')}}
if(mobOv){mobOv.onclick=function(){sidebar.classList.remove('open');mobOv.classList.remove('open')}}
</script>
</body></html>
