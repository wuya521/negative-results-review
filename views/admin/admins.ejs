<%- include('partials/head', { pageTitle: '馆务成员' }) %>
<body>
<div class="layout">
<%- include('partials/sidebar', { active: 'admins', stats: stats, admin: admin }) %>
<div class="main">
  <header class="topbar">
    <div class="topbar-left">
      <button class="topbar-menu" id="menuBtn" aria-label="菜单">☰</button>
      <span class="topbar-issue">CURATOR BOARD</span>
      <span class="topbar-status"><span class="dot"></span>联合馆长与馆务成员管理</span>
    </div>
  </header>

  <div class="content">
    <% if (msg) { %>
    <div class="detail-card" style="margin-bottom:1rem;font-size:.82rem;color:var(--text-sec)">
      <%= ({ added: '馆务成员已创建。', deleted: '成员已移除。', exists: '该用户名已存在。', invalid: '请检查用户名与密码。', self: '不能删除当前登录账号。', profile_saved: '成员资料已保存。' })[msg] || msg %>
    </div>
    <% } %>

    <div class="sec-header">
      <h2>馆务成员</h2>
      <span class="tag">Board Management</span>
    </div>

    <section class="detail-card member-admin-inline-card" style="margin-bottom:1.5rem">
      <h3 class="member-admin-section-title">新增成员</h3>
      <form method="POST" action="/admin/admins/add" class="member-form-stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="edit-grid">
          <label class="member-form-field"><span>用户名</span><input type="text" name="username" required></label>
          <label class="member-form-field"><span>初始密码</span><input type="password" name="password" minlength="6" required></label>
          <label class="member-form-field"><span>角色</span>
            <select name="role">
              <option value="co_curator">联合馆长</option>
              <option value="editor">编辑策展</option>
              <option value="reviewer">审稿</option>
              <option value="admin">创馆人</option>
            </select>
          </label>
        </div>
        <div class="edit-grid">
          <label class="member-form-field"><span>展示名</span><input type="text" name="display_name" placeholder="前台显示名称"></label>
          <label class="member-form-field"><span>前台头衔</span><input type="text" name="title" placeholder="Co-Curator / 联合馆长"></label>
          <label class="member-form-field"><span>徽章文案</span><input type="text" name="badge_label" placeholder="CO-CURATOR"></label>
        </div>
        <div class="edit-grid">
          <label class="member-form-field"><span>公开 slug</span><input type="text" name="public_slug" placeholder="co-curator"></label>
          <label class="edit-check" style="align-self:end"><input type="checkbox" name="is_public" value="1" checked> 公开展示在前台</label>
        </div>
        <button type="submit" class="btn-save">创建成员</button>
      </form>
    </section>

    <div class="member-admin-stack">
      <% admins.forEach(function(item) { %>
      <section class="detail-card admin-profile-card">
        <div class="admin-profile-card__head">
          <div>
            <div class="member-item__eyebrow"><%= item.username %> · <%= getAdminRoleLabel(item.role) %></div>
            <h3 class="member-admin-section-title"><%= item.display_name || item.username %></h3>
            <p class="member-admin-status-text"><%= item.title || '未设置公开头衔' %></p>
          </div>
          <div class="member-item__meta-block">
            <span class="member-badge member-badge--approved"><%= item.badge_label || getAdminRoleLabel(item.role) %></span>
            <span class="member-link"><%= item.is_public ? '前台公开' : '仅后台可见' %></span>
          </div>
        </div>
        <form method="POST" action="/admin/admins/<%= item.id %>/profile" class="member-form-stack">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="edit-grid">
            <label class="member-form-field"><span>角色</span>
              <select name="role">
                <option value="admin" <%= item.role === 'admin' ? 'selected' : '' %>>创馆人</option>
                <option value="co_curator" <%= item.role === 'co_curator' ? 'selected' : '' %>>联合馆长</option>
                <option value="editor" <%= item.role === 'editor' ? 'selected' : '' %>>编辑策展</option>
                <option value="reviewer" <%= item.role === 'reviewer' ? 'selected' : '' %>>审稿</option>
              </select>
            </label>
            <label class="member-form-field"><span>展示名</span><input type="text" name="display_name" value="<%= item.display_name || '' %>"></label>
            <label class="member-form-field"><span>前台头衔</span><input type="text" name="title" value="<%= item.title || '' %>"></label>
          </div>
          <div class="edit-grid">
            <label class="member-form-field"><span>徽章文案</span><input type="text" name="badge_label" value="<%= item.badge_label || '' %>"></label>
            <label class="member-form-field"><span>公开 slug</span><input type="text" name="public_slug" value="<%= item.public_slug || '' %>"></label>
            <label class="edit-check" style="align-self:end"><input type="checkbox" name="is_public" value="1" <%= item.is_public ? 'checked' : '' %>> 前台公开展示</label>
          </div>
          <label class="member-form-field"><span>简介</span><textarea name="bio" rows="4"><%= item.bio || '' %></textarea></label>
          <div class="admin-profile-card__actions">
            <button type="submit" class="btn-save">保存资料</button>
            <% if (item.id !== admin.id) { %>
            <button type="submit" class="act-btn danger" formaction="/admin/admins/<%= item.id %>/delete" onclick="return confirm('确认移除该馆务成员？')">删除成员</button>
            <% } %>
          </div>
        </form>
      </section>
      <% }) %>
    </div>
  </div>
</div>
</div>
<script>
var menuBtn=document.getElementById('menuBtn'),sidebar=document.getElementById('sidebar'),mobOv=document.getElementById('mobileOverlay');
if(menuBtn){menuBtn.onclick=function(){sidebar.classList.add('open');if(mobOv)mobOv.classList.add('open')}}
if(mobOv){mobOv.onclick=function(){sidebar.classList.remove('open');mobOv.classList.remove('open')}}
</script>
</body></html>
