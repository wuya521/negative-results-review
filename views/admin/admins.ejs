<%- include('partials/head', { pageTitle: '管理员管理' }) %>
<body>
<div class="layout">
<%- include('partials/sidebar', { active: 'admins', stats: stats, admin: admin }) %>
<div class="main">
  <header class="topbar">
    <div class="topbar-left">
      <button class="topbar-menu" id="menuBtn" aria-label="菜单">☰</button>
      <span class="topbar-issue">ISSUE 001</span>
      <span class="topbar-status"><span class="dot"></span>管理员管理</span>
    </div>
    <div class="topbar-right"></div>
  </header>

  <div class="content">
    <% if (msg) { %>
    <div class="toast show" style="position:relative;bottom:auto;right:auto;margin-bottom:1rem;pointer-events:auto;opacity:1;transform:none">
      <%= ({added:'管理员已添加',deleted:'管理员已删除',exists:'用户名已存在',invalid:'请填写完整信息（密码至少6位）',self:'不能删除自己'})[msg] || msg %>
    </div>
    <% } %>

    <div class="sec-header">
      <h2>管理员列表</h2>
      <span class="tag">Admin Management</span>
    </div>

    <div class="ms-list" style="margin-bottom:2rem">
      <div class="ms-head" style="grid-template-columns:40px 1fr 100px 150px auto">
        <span>#</span><span>用户名</span><span>角色</span><span>创建时间</span><span>操作</span>
      </div>
      <% admins.forEach(function(a, i) { %>
      <div class="ms-item" style="grid-template-columns:40px 1fr 100px 150px auto;cursor:default">
        <span class="ms-idx"><%= i+1 %></span>
        <span style="font-weight:500"><%= a.username %></span>
        <span class="badge badge-<%= a.role==='admin'?'accepted':'pending' %>"><%= ({admin:'超级管理员',editor:'编辑',reviewer:'审核员'})[a.role] || a.role %></span>
        <span class="ms-date"><%= a.created_at %></span>
        <span>
          <% if (a.id !== admin.id) { %>
          <form method="POST" action="/admin/admins/<%= a.id %>/delete" style="display:inline" onsubmit="return confirm('确认删除管理员 <%= a.username %>？')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="act-btn danger" style="padding:.3rem .6rem;font-size:.68rem">删除</button>
          </form>
          <% } else { %>
          <span style="font-size:.68rem;color:var(--text-light)">当前账号</span>
          <% } %>
        </span>
      </div>
      <% }) %>
    </div>

    <!-- Add admin form -->
    <div class="edit-card">
      <h3>添加管理员</h3>
      <form method="POST" action="/admin/admins/add">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="edit-grid">
          <div class="edit-field">
            <label>用户名</label>
            <input type="text" name="username" required placeholder="新管理员用户名">
          </div>
          <div class="edit-field">
            <label>密码</label>
            <input type="password" name="password" required placeholder="至少6位" minlength="6">
          </div>
          <div class="edit-field">
            <label>角色</label>
            <select name="role">
              <option value="editor">编辑</option>
              <option value="reviewer">审核员</option>
              <option value="admin">超级管理员</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn-save" style="margin-top:1rem">添加</button>
      </form>
    </div>
  </div>
</div>
</div>

<script>
var menuBtn=document.getElementById('menuBtn'),sidebar=document.getElementById('sidebar'),mobOv=document.getElementById('mobileOverlay');
if(menuBtn){menuBtn.onclick=function(){sidebar.classList.add('open');if(mobOv)mobOv.classList.add('open')}}
if(mobOv){mobOv.onclick=function(){sidebar.classList.remove('open');mobOv.classList.remove('open')}}
</script>
</body></html>
