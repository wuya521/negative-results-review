<%- include('partials/head', { pageTitle: ms.title }) %>
<body>
<div class="layout">
<%- include('partials/sidebar', { active: 'all', stats: stats, admin: admin }) %>
<div class="main">
  <header class="topbar">
    <div class="topbar-left">
      <button class="topbar-menu" id="menuBtn" aria-label="菜单">☰</button>
      <span class="topbar-issue"><%= ms.issue_label || 'ISSUE / DRAFT' %></span>
      <span class="topbar-status"><span class="dot"></span>馆务工作台</span>
    </div>
    <div class="topbar-right">
      <div class="topbar-stat"><div class="num"><%= ms.view_count || 0 %></div><div class="label">阅读</div></div>
      <div class="topbar-divider"></div>
      <div class="topbar-stat"><div class="num"><%= versions ? versions.length : 0 %></div><div class="label">版本</div></div>
    </div>
  </header>

  <div class="content">
    <a href="/admin/manuscripts" class="detail-back">← 返回稿件列表</a>

    <% if (msg) { %>
    <div class="detail-card" style="margin-bottom:1rem;font-size:.82rem;color:var(--text-sec)">
      <%= ({ saved:'审核信息已保存。', content_saved:'原稿内容已更新。', content_empty:'标题和正文不能为空。', optimized:'已生成整理稿。', no_optimized:'当前没有可应用的整理稿。', published_copy_saved:'整理稿已写入发布稿。', publication_saved:'馆藏版设置已保存。', invalid:'无效操作。' })[msg] || ({ status_pending:'状态已重置为待审。', status_under_review:'稿件已进入审核中。', status_revision:'稿件已退修。', status_accepted:'稿件已录用。', status_rejected:'稿件已拒稿。', status_published:'稿件已正式入馆。', status_archived:'稿件已归档。' })[msg] || msg %>
    </div>
    <% } %>

    <section class="detail-card" style="margin-bottom:1.5rem">
      <h1 class="detail-title"><%= ms.display_title || ms.title %></h1>
      <div class="detail-badges">
        <span class="badge badge-<%= ms.status %>"><%= statusLabel(ms.status) %></span>
        <span style="font-size:.68rem;color:var(--accent);border:1px solid var(--accent);padding:2px 8px;border-radius:1px"><%= ms.section %></span>
        <% if (ms.is_pinned) { %><span class="tag-badge tag-pinned">置顶</span><% } %>
        <% if (ms.is_editor_pick) { %><span class="tag-badge tag-editor-pick">编辑推荐</span><% } %>
        <% if (ms.is_trending) { %><span class="tag-badge tag-trending">加热中</span><% } %>
        <% if (ms.is_featured) { %><span class="tag-badge tag-featured">精选</span><% } %>
      </div>
      <div class="detail-meta">
        <div class="meta-item"><div class="ml">Submission</div><div class="mv mono"><%= ms.submission_no %></div></div>
        <div class="meta-item"><div class="ml">馆藏编号</div><div class="mv mono"><%= ms.archive_code || '未设定' %></div></div>
        <div class="meta-item"><div class="ml">馆藏级别</div><div class="mv"><%= getArchiveGradeMeta(ms.archive_grade).label %></div></div>
        <div class="meta-item"><div class="ml">学科方向</div><div class="mv"><%= ms.discipline %></div></div>
        <div class="meta-item"><div class="ml">刊标</div><div class="mv"><%= ms.publication_label || '未设置' %></div></div>
        <div class="meta-item"><div class="ml">当前策展署名</div><div class="mv"><%= ms.curator_display_name || ms.curator_username || '未指定' %></div></div>
        <div class="meta-item"><div class="ml">当前负责人</div><div class="mv"><%= ms.assignee_display_name || ms.assignee_username || '未指定' %></div></div>
        <div class="meta-item"><div class="ml">创建时间</div><div class="mv mono"><%= ms.created_at %></div></div>
      </div>
      <% if (owner) { %>
      <div style="margin-top:1rem;padding:1rem 1.1rem;border:1px solid var(--border);background:var(--bg-alt);font-size:.8rem;line-height:1.8;color:var(--text-sec)">
        绑定会员：<strong><%= owner.display_name %></strong> · <span class="mono"><%= owner.email %></span><br>
        会员等级：<strong><%= owner.member_tier %></strong> · 账号状态：<strong><%= owner.is_active ? '启用' : '停用' %></strong>
      </div>
      <% } %>
    </section>

    <div class="member-admin-actions-grid">
      <section class="edit-card member-admin-inline-card">
        <h3>原稿编辑</h3>
        <form method="POST" action="/admin/manuscripts/<%= ms.id %>/content" class="member-form-stack">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label class="member-form-field"><span>标题</span><input type="text" name="title" value="<%= ms.title %>" required></label>
          <label class="member-form-field"><span>原稿正文</span><textarea name="content" rows="16" required><%= ms.content %></textarea></label>
          <button type="submit" class="btn-save">保存原稿</button>
        </form>
      </section>

      <section class="edit-card member-admin-inline-card">
        <h3>排版工作台</h3>
        <p class="member-admin-status-text">保留原稿，生成整理稿，再决定是否写入发布稿。适合你和联合馆长分工处理。</p>
        <form method="POST" action="/admin/manuscripts/<%= ms.id %>/optimize" style="margin-bottom:1rem">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="act-btn blue">一键整理为馆藏排版</button>
        </form>
        <form method="POST" action="/admin/manuscripts/<%= ms.id %>/apply-optimized" style="margin-bottom:1rem">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="act-btn green">将整理稿写入发布稿</button>
        </form>
        <label class="member-form-field"><span>整理稿预览</span><textarea rows="16" readonly><%= ms.optimized_content || '尚未生成整理稿。' %></textarea></label>
      </section>
    </div>

    <form method="POST" action="/admin/manuscripts/<%= ms.id %>/publication" class="edit-card" style="margin-top:1.5rem">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <h3>馆藏版 / 期刊版设置</h3>
      <div class="edit-grid">
        <label class="member-form-field"><span>显示标题</span><input type="text" name="display_title" value="<%= ms.display_title || '' %>"></label>
        <label class="member-form-field"><span>刊标文字</span><input type="text" name="publication_label" value="<%= ms.publication_label || '' %>"></label>
        <label class="member-form-field"><span>馆藏编号</span><input type="text" name="archive_code" value="<%= ms.archive_code || '' %>" placeholder="ISSUE-001-A014"></label>
      </div>
      <div class="edit-grid">
        <label class="member-form-field"><span>导语 / Deck</span><input type="text" name="deck" value="<%= ms.deck || '' %>"></label>
        <label class="member-form-field"><span>馆藏级别</span>
          <select name="archive_grade">
            <option value="standard" <%= (ms.archive_grade || 'standard') === 'standard' ? 'selected' : '' %>>正式馆藏</option>
            <option value="featured" <%= ms.archive_grade === 'featured' ? 'selected' : '' %>>策展精选</option>
            <option value="dossier" <%= ms.archive_grade === 'dossier' ? 'selected' : '' %>>专题卷宗</option>
            <option value="honor" <%= ms.archive_grade === 'honor' ? 'selected' : '' %>>荣誉入藏</option>
          </select>
        </label>
        <label class="member-form-field"><span>期号归属</span>
          <select name="issue_id">
            <option value="">不绑定期号</option>
            <% issues.forEach(function(issue) { %>
            <option value="<%= issue.id %>" <%= String(ms.issue_id || '') === String(issue.id) ? 'selected' : '' %>><%= issue.issue_label %> · <%= issue.year %> <%= issue.season || '' %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <div class="edit-grid">
        <label class="member-form-field"><span>摘要 / Excerpt</span><textarea name="excerpt" rows="4"><%= ms.excerpt || '' %></textarea></label>
        <label class="member-form-field"><span>版式模板</span>
          <select name="layout_style">
            <% ['journal','broadside','archive'].forEach(function(style) { %>
            <option value="<%= style %>" <%= (ms.layout_style || 'journal') === style ? 'selected' : '' %>><%= style %></option>
            <% }) %>
          </select>
          <label class="edit-check" style="margin-top:1rem"><input type="checkbox" name="pdf_enabled" value="1" <%= ms.pdf_enabled ? 'checked' : '' %>> 开放 PDF / 打印版入口</label>
        </label>
      </div>
      <label class="member-form-field"><span>发布稿正文</span><textarea name="published_content" rows="18"><%= ms.published_content || '' %></textarea></label>
      <button type="submit" class="btn-save">保存馆藏版设置</button>
    </form>

    <form method="POST" action="/admin/manuscripts/<%= ms.id %>" class="edit-card" style="margin-top:1.5rem">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <h3>审核信息与协作分工</h3>
      <div class="edit-grid">
        <label class="member-form-field"><span>风险等级</span>
          <select name="risk_level">
            <option value="low" <%= ms.risk_level==='low'?'selected':'' %>>低</option>
            <option value="medium" <%= ms.risk_level==='medium'?'selected':'' %>>中</option>
            <option value="high" <%= ms.risk_level==='high'?'selected':'' %>>高</option>
          </select>
        </label>
        <label class="member-form-field"><span>脱敏状态</span>
          <select name="desensitized_status">
            <option value="unchecked" <%= ms.desensitized_status==='unchecked'?'selected':'' %>>未检查</option>
            <option value="passed" <%= ms.desensitized_status==='passed'?'selected':'' %>>已通过</option>
            <option value="failed" <%= ms.desensitized_status==='failed'?'selected':'' %>>未通过</option>
          </select>
        </label>
        <label class="member-form-field"><span>策展署名</span>
          <select name="curator_admin_id">
            <option value="">未指定</option>
            <% adminOptions.forEach(function(option) { %>
            <option value="<%= option.id %>" <%= String(ms.curator_admin_id || '') === String(option.id) ? 'selected' : '' %>><%= option.display_name || option.username %> · <%= getAdminRoleLabel(option.role) %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <div class="edit-grid">
        <label class="member-form-field"><span>当前负责人</span>
          <select name="assigned_admin_id">
            <option value="">未指定</option>
            <% adminOptions.forEach(function(option) { %>
            <option value="<%= option.id %>" <%= String(ms.assigned_admin_id || '') === String(option.id) ? 'selected' : '' %>><%= option.display_name || option.username %> · <%= getAdminRoleLabel(option.role) %></option>
            <% }) %>
          </select>
        </label>
        <label class="member-form-field"><span>标签</span><input type="text" name="tags" value="<%= ms.tags || '' %>" placeholder="逗号分隔"></label>
        <label class="member-form-field"><span>馆藏编号（同步）</span><input type="text" name="archive_code" value="<%= ms.archive_code || '' %>"></label>
      </div>
      <div class="edit-grid">
        <label class="member-form-field"><span>馆藏级别</span>
          <select name="archive_grade">
            <option value="standard" <%= (ms.archive_grade || 'standard') === 'standard' ? 'selected' : '' %>>正式馆藏</option>
            <option value="featured" <%= ms.archive_grade === 'featured' ? 'selected' : '' %>>策展精选</option>
            <option value="dossier" <%= ms.archive_grade === 'dossier' ? 'selected' : '' %>>专题卷宗</option>
            <option value="honor" <%= ms.archive_grade === 'honor' ? 'selected' : '' %>>荣誉入藏</option>
          </select>
        </label>
      </div>
      <div style="display:flex;gap:1.25rem;flex-wrap:wrap;margin:1rem 0">
        <label class="edit-check"><input type="checkbox" name="is_featured" value="1" <%= ms.is_featured?'checked':'' %>> 精选</label>
        <label class="edit-check"><input type="checkbox" name="is_pinned" value="1" <%= ms.is_pinned?'checked':'' %>> 置顶</label>
        <label class="edit-check"><input type="checkbox" name="is_editor_pick" value="1" <%= ms.is_editor_pick?'checked':'' %>> 编辑推荐</label>
        <label class="edit-check"><input type="checkbox" name="is_trending" value="1" <%= ms.is_trending?'checked':'' %>> 加热中</label>
      </div>
      <label class="member-form-field"><span>馆方存档意见</span><textarea name="curator_note" rows="5"><%= ms.curator_note || '' %></textarea></label>
      <label class="member-form-field"><span>编辑备注</span><textarea name="editor_note" rows="5"><%= ms.editor_note || '' %></textarea></label>
      <label class="member-form-field"><span>内部协作备注</span><textarea name="internal_note" rows="5"><%= ms.internal_note || '' %></textarea></label>
      <button type="submit" class="btn-save">保存审核与协作信息</button>
    </form>

    <section class="status-card" style="margin-top:1.5rem">
      <h3>状态流转</h3>
      <p>当前状态：<strong><%= statusLabel(ms.status) %></strong></p>
      <div class="status-actions">
        <% var actions = [];
           if (ms.status === 'pending') actions.push({s:'under_review',l:'标记为审核中',c:'blue',confirm:false});
           if (['pending','under_review'].includes(ms.status)) {
             actions.push({s:'revision',l:'退修',c:'amber',confirm:true});
             actions.push({s:'accepted',l:'录用',c:'green',confirm:true});
             actions.push({s:'rejected',l:'拒稿',c:'danger',confirm:true});
           }
           if (ms.status === 'revision') {
             actions.push({s:'under_review',l:'重新审核',c:'blue',confirm:false});
             actions.push({s:'accepted',l:'录用',c:'green',confirm:true});
             actions.push({s:'rejected',l:'拒稿',c:'danger',confirm:true});
           }
           if (ms.status === 'accepted') actions.push({s:'published',l:'正式入馆',c:'primary',confirm:true});
           if (ms.status === 'published') actions.push({s:'archived',l:'归档',c:'',confirm:true});
           if (['rejected','archived'].includes(ms.status)) actions.push({s:'pending',l:'重置为待审',c:'',confirm:true});
        %>
        <% actions.forEach(function(a) { %>
        <form method="POST" action="/admin/manuscripts/<%= ms.id %>/status" style="display:inline" <% if (a.confirm) { %>onsubmit="return confirm('确认将此稿件设为「<%= statusLabel(a.s) %>」？')"<% } %>>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="status" value="<%= a.s %>">
          <button type="submit" class="act-btn <%= a.c %>"><%= a.l %></button>
        </form>
        <% }) %>
      </div>
    </section>

    <div class="member-admin-split" style="margin-top:1.5rem">
      <section class="detail-card">
        <h3 class="member-admin-section-title">版本记录</h3>
        <% if (versions && versions.length) { %>
        <div class="member-admin-stack">
          <% versions.forEach(function(version) { %>
          <article class="member-admin-record">
            <div>
              <div class="member-item__eyebrow"><%= version.version_type %> · <%= version.created_at %></div>
              <h4><%= version.title %></h4>
              <p><%= String(version.content || '').replace(/[#>*`\-]/g, '').slice(0, 180) %></p>
            </div>
          </article>
          <% }) %>
        </div>
        <% } else { %>
        <p class="member-empty">还没有生成版本记录。</p>
        <% } %>
      </section>

      <section class="detail-card">
        <h3 class="member-admin-section-title">操作记录</h3>
        <% if (logs && logs.length) { %>
        <div class="log-list">
          <% logs.forEach(function(log) { %>
          <div class="log-item">
            <span class="log-time"><%= log.created_at %></span>
            <span class="log-admin"><%= log.admin_name %></span>
            <span class="log-action"><%= log.action %></span>
            <% if (log.details) { %><span class="log-detail"><%= log.details %></span><% } %>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="member-empty">还没有操作记录。</p>
        <% } %>
      </section>
    </div>
  </div>
</div>
</div>
<script>
var menuBtn=document.getElementById('menuBtn'),sidebar=document.getElementById('sidebar'),mobOv=document.getElementById('mobileOverlay');
if(menuBtn){menuBtn.onclick=function(){sidebar.classList.add('open');if(mobOv)mobOv.classList.add('open')}}
if(mobOv){mobOv.onclick=function(){sidebar.classList.remove('open');mobOv.classList.remove('open')}}
</script>
</body></html>
