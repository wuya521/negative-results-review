<%- include('partials/head', { pageTitle: '投稿' }) %>
<%- include('partials/nav') %>

<header class="page-header">
  <div class="container">
    <p class="page-header__label">Submit / 投稿</p>
    <h1 class="page-header__title">向编辑部投稿</h1>
    <p class="page-header__sub">无论是失败的实验、被拒的论文，还是一段真实的科研情绪，如果你觉得它值得被记录，请在此提交。所有投稿均可匿名。</p>
  </div>
</header>

<main class="section">
  <div class="container">

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="form-alert form-alert--success">
      <h3>投稿已成功提交</h3>
      <p>编辑部将在 7 个工作日内审阅。</p>
      <% if (typeof submissionNo !== 'undefined' && submissionNo) { %>
      <div class="submission-ticket">
        <span>你的稿件编号</span>
        <strong><%= submissionNo %></strong>
      </div>
      <p>你可以在 <a href="/track?no=<%= submissionNo %>">稿件追踪</a> 页面查询进度。</p>
      <% } %>
    </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="form-alert form-alert--error"><%= error %></div>
    <% } %>

    <% if (memberHint) { %>
    <div class="member-banner"><%= memberHint %></div>
    <% } %>

    <div class="form-wrapper">
      <form class="form-main" method="POST" action="/submit" id="submitForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
          <label class="form-label" for="title">稿件标题 <span class="required">*</span></label>
          <input class="form-input" type="text" id="title" name="title" required value="<%= typeof form !== 'undefined' && form && form.title ? form.title : '' %>">
        </div>

        <div class="form-group auth-grid">
          <div>
            <label class="form-label" for="discipline">学科方向 <span class="required">*</span></label>
            <input class="form-input" type="text" id="discipline" name="discipline" required value="<%= typeof form !== 'undefined' && form && form.discipline ? form.discipline : '' %>">
          </div>
          <div>
            <label class="form-label" for="section">投稿栏目 <span class="required">*</span></label>
            <select class="form-select" id="section" name="section" required>
              <option value="" disabled selected>请选择栏目</option>
              <% sections.forEach(function(s) { %>
              <option value="<%= s %>" <%= (typeof form !== 'undefined' && form && form.section === s) ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="author_mode">署名方式</label>
          <select class="form-select" id="author_mode" name="author_mode">
            <option value="anonymous" selected>匿名发表</option>
            <option value="pen_name">使用笔名</option>
            <option value="real_name">使用真实姓名</option>
          </select>
          <span class="form-hint">会员身份仅用于站内归属，不会覆盖你选择的公开署名方式。</span>
        </div>

        <div class="form-group" id="penNameGroup" style="display:none">
          <label class="form-label" for="pen_name">笔名 / 姓名</label>
          <input class="form-input" type="text" id="pen_name" name="pen_name" value="<%= typeof form !== 'undefined' && form && form.pen_name ? form.pen_name : '' %>">
        </div>

        <div class="form-group">
          <label class="form-label" for="content">正文内容 <span class="required">*</span></label>
          <div class="editor-toolbar">
            <button type="button" class="editor-btn" onclick="insertMd('**','**')" title="加粗">B</button>
            <button type="button" class="editor-btn" onclick="insertMd('*','*')" title="斜体"><em>I</em></button>
            <button type="button" class="editor-btn" onclick="insertMd('\n> ','')" title="引用">❝</button>
            <button type="button" class="editor-btn" onclick="insertMd('\n## ','')" title="小标题">H</button>
            <button type="button" class="editor-btn" onclick="insertMd('\n---\n','')" title="分隔线">─</button>
            <span class="editor-hint">现在会按 Markdown 正式渲染文章结构</span>
          </div>
          <textarea class="form-textarea" id="content" name="content" required><%= typeof form !== 'undefined' && form && form.content ? form.content : '' %></textarea>
          <div class="char-counter">
            <span id="charCount">已输入 0 字</span>
            <span class="char-range">建议 500-3000 字</span>
            <span class="autosave-hint" id="autosaveHint"></span>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="value_note">一句话说明：这篇内容对别人有什么价值？</label>
          <input class="form-input" type="text" id="value_note" name="value_note" value="<%= typeof form !== 'undefined' && form && form.value_note ? form.value_note : '' %>">
        </div>

        <div class="form-group">
          <label class="form-check">
            <input type="checkbox" name="agree" value="1" required>
            <span>我确认以上内容为本人真实经历或观点，不涉及捏造、诽谤或侵犯他人知识产权，并理解本平台为非正式学术交流空间。 <span class="required">*</span></span>
          </label>
        </div>

        <button class="btn-submit" type="submit">提交投稿</button>
      </form>

      <aside class="form-sidebar">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">会员加成</h3>
          <div class="sidebar-card__body">
            <p>注册会员后，你将获得：</p>
            <ul>
              <li>投稿自动归入个人工作台</li>
              <li>审核状态通知</li>
              <li>文章收藏清单</li>
            </ul>
          </div>
        </div>
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Markdown 支持</h3>
          <div class="sidebar-card__body">
            <ul>
              <li><code>## 小标题</code> 用于分节</li>
              <li><code>**加粗**</code> 强调关键句</li>
              <li><code>&gt; 引用</code> 放置审稿意见或原话</li>
              <li><code>---</code> 插入文中转折</li>
            </ul>
          </div>
        </div>
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">稿件追踪</h3>
          <div class="sidebar-card__body">
            <p>投稿成功后将获得唯一编号，可在 <a href="/track">稿件追踪</a> 页面查询进度。</p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<script>
document.getElementById('author_mode').addEventListener('change', function(){
  document.getElementById('penNameGroup').style.display = this.value !== 'anonymous' ? '' : 'none';
});

var ta = document.getElementById('content');
var cc = document.getElementById('charCount');
if (ta && cc) {
  function updateCount(){
    var len = ta.value.length;
    cc.textContent = '已输入 ' + len + ' 字';
    cc.style.color = (len >= 500 && len <= 3000) ? '#3A7D44' : (len > 3000 ? '#8B2500' : '');
  }
  ta.addEventListener('input', updateCount);
  updateCount();
}

function insertMd(before, after) {
  var ta = document.getElementById('content');
  var start = ta.selectionStart, end = ta.selectionEnd;
  var sel = ta.value.substring(start, end);
  ta.value = ta.value.substring(0, start) + before + sel + after + ta.value.substring(end);
  ta.focus();
  ta.selectionStart = start + before.length;
  ta.selectionEnd = start + before.length + sel.length;
  ta.dispatchEvent(new Event('input'));
}

(function(){
  var form = document.getElementById('submitForm');
  var key = 'nrr-draft';
  var hint = document.getElementById('autosaveHint');
  var fields = ['title','discipline','section','content','value_note','pen_name'];

  function saveDraft(){
    var data = {};
    fields.forEach(function(f){
      var el = document.getElementById(f);
      if(el) data[f] = el.value;
    });
    localStorage.setItem(key, JSON.stringify(data));
    if(hint) { hint.textContent = '草稿已自动保存'; setTimeout(function(){ hint.textContent=''; }, 2000); }
  }

  function loadDraft(){
    try{
      var d = JSON.parse(localStorage.getItem(key));
      if(!d) return;
      var hasContent = false;
      fields.forEach(function(f){
        var el = document.getElementById(f);
        if(el && d[f] && !el.value){
          el.value = d[f];
          hasContent = true;
        }
      });
      if(hasContent && hint) hint.textContent = '已恢复上次草稿';
    }catch(e){}
  }

  var isSuccess = '<%= typeof success !== "undefined" && success ? "1" : "" %>';
  if(!isSuccess) loadDraft();

  fields.forEach(function(f){
    var el = document.getElementById(f);
    if(el) el.addEventListener('input', function(){ clearTimeout(window._saveTimer); window._saveTimer = setTimeout(saveDraft, 2000); });
  });

  if(form) form.addEventListener('submit', function(){ localStorage.removeItem(key); });
  if(isSuccess) localStorage.removeItem(key);
})();
</script>
